{
    "dashboard": {
        "title": "hls-scte35 Pipeline",
        "tags": [
            "hls",
            "scte35",
            "tsduck"
        ],
        "timezone": "browser",
        "refresh": "15s",
        "time": {
            "from": "now-1h",
            "to": "now"
        },
        "panels": [
            {
                "id": 1,
                "title": "Pipeline State",
                "type": "timeseries",
                "gridPos": {
                    "h": 8,
                    "w": 8,
                    "x": 0,
                    "y": 0
                },
                "targets": [
                    {
                        "expr": "pipeline_state",
                        "legendFormat": "{{id}}",
                        "refId": "A"
                    }
                ],
                "datasource": {
                    "type": "prometheus",
                    "uid": "PBFA97CFB590B2093"
                },
                "fieldConfig": {
                    "defaults": {
                        "min": 0,
                        "max": 1,
                        "thresholds": {
                            "mode": "absolute",
                            "steps": [
                                {
                                    "color": "red",
                                    "value": null
                                },
                                {
                                    "color": "yellow",
                                    "value": 0.5
                                },
                                {
                                    "color": "green",
                                    "value": 1
                                }
                            ]
                        },
                        "custom": {
                            "fillOpacity": 20
                        }
                    }
                }
            },
            {
                "id": 2,
                "title": "Active Pipelines",
                "type": "stat",
                "gridPos": {
                    "h": 8,
                    "w": 4,
                    "x": 8,
                    "y": 0
                },
                "targets": [
                    {
                        "expr": "active_pipelines",
                        "legendFormat": "Active",
                        "refId": "A"
                    }
                ],
                "datasource": {
                    "type": "prometheus",
                    "uid": "PBFA97CFB590B2093"
                },
                "fieldConfig": {
                    "defaults": {
                        "color": {
                            "mode": "thresholds"
                        },
                        "thresholds": {
                            "steps": [
                                {
                                    "color": "green",
                                    "value": null
                                }
                            ]
                        }
                    }
                }
            },
            {
                "id": 3,
                "title": "Created / Stopped / Failed",
                "type": "stat",
                "gridPos": {
                    "h": 8,
                    "w": 6,
                    "x": 12,
                    "y": 0
                },
                "targets": [
                    {
                        "expr": "pipelines_created_total",
                        "legendFormat": "Created",
                        "refId": "A"
                    },
                    {
                        "expr": "pipelines_stopped_total",
                        "legendFormat": "Stopped",
                        "refId": "B"
                    },
                    {
                        "expr": "pipelines_failed_total",
                        "legendFormat": "Failed",
                        "refId": "C"
                    }
                ],
                "datasource": {
                    "type": "prometheus",
                    "uid": "PBFA97CFB590B2093"
                }
            },
            {
                "id": 4,
                "title": "Pipeline Restarts (5m)",
                "type": "timeseries",
                "gridPos": {
                    "h": 8,
                    "w": 6,
                    "x": 18,
                    "y": 0
                },
                "targets": [
                    {
                        "expr": "increase(pipeline_restarts_total[5m])",
                        "legendFormat": "{{id}} {{process}}",
                        "refId": "A"
                    }
                ],
                "datasource": {
                    "type": "prometheus",
                    "uid": "PBFA97CFB590B2093"
                },
                "fieldConfig": {
                    "defaults": {
                        "custom": {
                            "fillOpacity": 30,
                            "drawStyle": "bars"
                        }
                    }
                }
            },
            {
                "id": 5,
                "title": "SCTE-35 Events Detected (per min)",
                "type": "timeseries",
                "gridPos": {
                    "h": 8,
                    "w": 12,
                    "x": 0,
                    "y": 8
                },
                "targets": [
                    {
                        "expr": "rate(scte35_events_detected_total[5m]) * 60",
                        "legendFormat": "{{type}}",
                        "refId": "A"
                    }
                ],
                "datasource": {
                    "type": "prometheus",
                    "uid": "PBFA97CFB590B2093"
                },
                "fieldConfig": {
                    "defaults": {
                        "unit": "cpm",
                        "custom": {
                            "fillOpacity": 20,
                            "stacking": {
                                "mode": "normal"
                            }
                        }
                    }
                }
            },
            {
                "id": 6,
                "title": "SCTE-35 Events Injected (per min)",
                "type": "timeseries",
                "gridPos": {
                    "h": 8,
                    "w": 12,
                    "x": 12,
                    "y": 8
                },
                "targets": [
                    {
                        "expr": "rate(scte35_events_injected_total[5m]) * 60",
                        "legendFormat": "{{format}}",
                        "refId": "A"
                    }
                ],
                "datasource": {
                    "type": "prometheus",
                    "uid": "PBFA97CFB590B2093"
                },
                "fieldConfig": {
                    "defaults": {
                        "unit": "cpm",
                        "custom": {
                            "fillOpacity": 20,
                            "stacking": {
                                "mode": "normal"
                            }
                        }
                    }
                }
            },
            {
                "id": 7,
                "title": "Manifest Poll Duration (avg)",
                "type": "timeseries",
                "gridPos": {
                    "h": 8,
                    "w": 8,
                    "x": 0,
                    "y": 16
                },
                "targets": [
                    {
                        "expr": "manifest_poll_duration_seconds_sum / manifest_poll_duration_seconds_count",
                        "legendFormat": "avg duration",
                        "refId": "A"
                    }
                ],
                "datasource": {
                    "type": "prometheus",
                    "uid": "PBFA97CFB590B2093"
                },
                "fieldConfig": {
                    "defaults": {
                        "unit": "s",
                        "custom": {
                            "fillOpacity": 10
                        }
                    }
                }
            },
            {
                "id": 8,
                "title": "Poll Error Rate",
                "type": "gauge",
                "gridPos": {
                    "h": 8,
                    "w": 4,
                    "x": 8,
                    "y": 16
                },
                "targets": [
                    {
                        "expr": "manifest_poll_errors_total / (manifest_poll_total > 0 or vector(1))",
                        "legendFormat": "Error %",
                        "refId": "A"
                    }
                ],
                "datasource": {
                    "type": "prometheus",
                    "uid": "PBFA97CFB590B2093"
                },
                "fieldConfig": {
                    "defaults": {
                        "unit": "percentunit",
                        "min": 0,
                        "max": 1,
                        "thresholds": {
                            "steps": [
                                {
                                    "color": "green",
                                    "value": null
                                },
                                {
                                    "color": "yellow",
                                    "value": 0.05
                                },
                                {
                                    "color": "red",
                                    "value": 0.1
                                }
                            ]
                        }
                    }
                }
            },
            {
                "id": 9,
                "title": "PTS Calibration",
                "type": "stat",
                "gridPos": {
                    "h": 8,
                    "w": 4,
                    "x": 12,
                    "y": 16
                },
                "targets": [
                    {
                        "expr": "pts_calibration_status",
                        "legendFormat": "Status",
                        "refId": "A"
                    }
                ],
                "datasource": {
                    "type": "prometheus",
                    "uid": "PBFA97CFB590B2093"
                },
                "fieldConfig": {
                    "defaults": {
                        "mappings": [
                            {
                                "type": "value",
                                "options": {
                                    "-1": {
                                        "text": "Disabled",
                                        "color": "text"
                                    },
                                    "0": {
                                        "text": "Pending",
                                        "color": "yellow"
                                    },
                                    "1": {
                                        "text": "Calibrated",
                                        "color": "green"
                                    }
                                }
                            }
                        ]
                    }
                }
            },
            {
                "id": 10,
                "title": "DRM Status",
                "type": "stat",
                "gridPos": {
                    "h": 4,
                    "w": 4,
                    "x": 16,
                    "y": 16
                },
                "targets": [
                    {
                        "expr": "drm_detected",
                        "legendFormat": "DRM",
                        "refId": "A"
                    }
                ],
                "datasource": {
                    "type": "prometheus",
                    "uid": "PBFA97CFB590B2093"
                },
                "fieldConfig": {
                    "defaults": {
                        "mappings": [
                            {
                                "type": "value",
                                "options": {
                                    "0": {
                                        "text": "No DRM",
                                        "color": "text"
                                    },
                                    "1": {
                                        "text": "DRM Active",
                                        "color": "orange"
                                    }
                                }
                            }
                        ]
                    }
                }
            },
            {
                "id": 11,
                "title": "Key Rotations",
                "type": "stat",
                "gridPos": {
                    "h": 4,
                    "w": 4,
                    "x": 16,
                    "y": 20
                },
                "targets": [
                    {
                        "expr": "drm_key_rotations_total",
                        "legendFormat": "Rotations",
                        "refId": "A"
                    }
                ],
                "datasource": {
                    "type": "prometheus",
                    "uid": "PBFA97CFB590B2093"
                }
            },
            {
                "id": 12,
                "title": "Calibration Attempts",
                "type": "stat",
                "gridPos": {
                    "h": 8,
                    "w": 4,
                    "x": 20,
                    "y": 16
                },
                "targets": [
                    {
                        "expr": "pts_calibration_attempts_total",
                        "legendFormat": "Attempts",
                        "refId": "A"
                    }
                ],
                "datasource": {
                    "type": "prometheus",
                    "uid": "PBFA97CFB590B2093"
                }
            },
            {
                "id": 13,
                "title": "Dedup Set Sizes",
                "type": "timeseries",
                "gridPos": {
                    "h": 8,
                    "w": 12,
                    "x": 0,
                    "y": 24
                },
                "targets": [
                    {
                        "expr": "seen_cues_size",
                        "legendFormat": "Seen Cues",
                        "refId": "A"
                    },
                    {
                        "expr": "seen_raw_hashes_size",
                        "legendFormat": "Raw Hashes",
                        "refId": "B"
                    }
                ],
                "datasource": {
                    "type": "prometheus",
                    "uid": "PBFA97CFB590B2093"
                }
            },
            {
                "id": 14,
                "title": "API Server Uptime",
                "type": "stat",
                "gridPos": {
                    "h": 8,
                    "w": 12,
                    "x": 12,
                    "y": 24
                },
                "targets": [
                    {
                        "expr": "time() - process_start_time_seconds{job=\"hls-scte35\"}",
                        "legendFormat": "Uptime",
                        "refId": "A"
                    }
                ],
                "datasource": {
                    "type": "prometheus",
                    "uid": "PBFA97CFB590B2093"
                },
                "fieldConfig": {
                    "defaults": {
                        "unit": "dtdurations"
                    }
                }
            },
            {
                "id": 15,
                "title": "CPU Utilization",
                "type": "timeseries",
                "gridPos": {
                    "h": 8,
                    "w": 12,
                    "x": 0,
                    "y": 32
                },
                "targets": [
                    {
                        "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[1m])) * 100)",
                        "legendFormat": "Total CPU %",
                        "refId": "A"
                    },
                    {
                        "expr": "avg by (mode) (rate(node_cpu_seconds_total{mode=~\"user|system\"}[1m])) * 100",
                        "legendFormat": "{{mode}}",
                        "refId": "B"
                    }
                ],
                "datasource": {
                    "type": "prometheus",
                    "uid": "PBFA97CFB590B2093"
                },
                "fieldConfig": {
                    "defaults": {
                        "unit": "percent",
                        "min": 0,
                        "max": 100,
                        "thresholds": {
                            "mode": "absolute",
                            "steps": [
                                {
                                    "color": "green",
                                    "value": null
                                },
                                {
                                    "color": "yellow",
                                    "value": 60
                                },
                                {
                                    "color": "red",
                                    "value": 85
                                }
                            ]
                        },
                        "custom": {
                            "fillOpacity": 15
                        }
                    }
                }
            },
            {
                "id": 16,
                "title": "Memory Usage",
                "type": "timeseries",
                "gridPos": {
                    "h": 8,
                    "w": 12,
                    "x": 12,
                    "y": 32
                },
                "targets": [
                    {
                        "expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100",
                        "legendFormat": "Used %",
                        "refId": "A"
                    }
                ],
                "datasource": {
                    "type": "prometheus",
                    "uid": "PBFA97CFB590B2093"
                },
                "fieldConfig": {
                    "defaults": {
                        "unit": "percent",
                        "min": 0,
                        "max": 100,
                        "thresholds": {
                            "mode": "absolute",
                            "steps": [
                                {
                                    "color": "green",
                                    "value": null
                                },
                                {
                                    "color": "yellow",
                                    "value": 70
                                },
                                {
                                    "color": "red",
                                    "value": 90
                                }
                            ]
                        },
                        "custom": {
                            "fillOpacity": 15
                        }
                    }
                }
            }
        ]
    },
    "overwrite": true
}
